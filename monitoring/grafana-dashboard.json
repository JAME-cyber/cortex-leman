{
  "dashboard": {
    "title": "Cortex Leman v5 — Tableau de Bord",
    "description": "Monitoring infrastructure de confiance IA",
    "tags": ["cortex-leman", "compliance", "rgpd"],
    "timezone": "Europe/Zurich",
    "panels": [
      {
        "title": "Requêtes HTTP/min",
        "type": "timeseries",
        "targets": [{"expr": "rate(cortex_http_requests_total[5m]) * 60"}],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "Latence HTTP (p95)",
        "type": "gauge",
        "targets": [{"expr": "histogram_quantile(0.95, rate(cortex_http_request_duration_seconds_bucket[5m]))"}],
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "title": "Appels LLM",
        "type": "timeseries",
        "targets": [
          {"expr": "rate(cortex_llm_calls_total{result=\"success\"}[5m])", "legendFormat": "Succès"},
          {"expr": "rate(cortex_llm_calls_total{result=\"error\"}[5m])", "legendFormat": "Erreur"},
          {"expr": "rate(cortex_llm_calls_total{result=\"guardrail_blocked\"}[5m])", "legendFormat": "Bloqué guardrail"}
        ],
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "title": "Intentions par vertical",
        "type": "piechart",
        "targets": [{"expr": "cortex_intentions_total"}],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
      },
      {
        "title": "Gels préventifs",
        "type": "timeseries",
        "targets": [{"expr": "rate(cortex_mediator_freezes_total[5m])"}],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}
      },
      {
        "title": "Arbitrages en attente",
        "type": "stat",
        "targets": [{"expr": "cortex_pending_arbitrations"}],
        "gridPos": {"h": 8, "w": 4, "x": 16, "y": 8}
      },
      {
        "title": "Authentifications",
        "type": "timeseries",
        "targets": [
          {"expr": "rate(cortex_auth_attempts_total{result=\"success\"}[5m])", "legendFormat": "Succès"},
          {"expr": "rate(cortex_auth_attempts_total{result=\"failure\"}[5m])", "legendFormat": "Échec"}
        ],
        "gridPos": {"h": 8, "w": 4, "x": 20, "y": 8}
      },
      {
        "title": "Circuit Breakers",
        "type": "stat",
        "targets": [{"expr": "cortex_circuit_breaker_state"}],
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 16}
      },
      {
        "title": "Guardrail Blocks",
        "type": "timeseries",
        "targets": [
          {"expr": "rate(cortex_guardrail_blocks_total{guard_type=\"pii\"}[5m])", "legendFormat": "PII"},
          {"expr": "rate(cortex_guardrail_blocks_total{guard_type=\"topic\"}[5m])", "legendFormat": "Topic"},
          {"expr": "rate(cortex_guardrail_blocks_total{guard_type=\"output\"}[5m])", "legendFormat": "Output"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20}
      },
      {
        "title": "RAG Chunks indexés",
        "type": "stat",
        "targets": [{"expr": "cortex_rag_chunks_indexed"}],
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 20}
      }
    ]
  }
}
