# Cortex Leman v5 — Configuration
# Mode: standard | haute_protection

APP_NAME=cortex-leman-v5
APP_VERSION=5.0.0
APP_ENV=development
APP_MODE=standard

# === NATS BUS ===
NATS_URL=nats://localhost:4222
NATS_CLUSTER=cortex-leman-cluster
NATS_CLIENT_ID=cortex-orchestrator
NATS_STREAM_NAME=CLEMAN_INTENTIONS
NATS_STREAM_SUBJECTS=cleman.>
NATS_MAX_AGE_DAYS=365
NATS_MAX_MSG_SIZE=1048576
NATS_REPLICAS=1

# === JOURNAL ===
JOURNAL_PATH=./data/journal
JOURNAL_HASH_ALGO=sha256
JOURNAL_SIGNING_KEY=change_this_in_production
JOURNAL_WORM=true

# === REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_LOCK_TIMEOUT=30

# === LLM ===
LLM_PROVIDER=openrouter
LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_TIMEOUT=60
LLM_MAX_TOKENS=4096

# EDGE: Mode Haute Protection
# LLM_PROVIDER=ollama
# LLM_MODEL=mistral:7b
# LLM_BASE_URL=http://localhost:11434

# === MEDIATOR ===
MEDIATOR_RULES_DIR=./core/mediator/rules
MEDIATOR_CONFLICT_THRESHOLD=0.7
MEDIATOR_FREEZE_ENABLED=true
# P1: Seuil de gel par défaut (CHF). Les verticales sensibles avec montant ≥ ce seuil
# déclenchent un gel dégradé si aucune règle explicite ne s'applique.
# Surchargeable par verticale dans le code Médiateur.
MEDIATOR_DEFAULT_FREEZE_THRESHOLD=10000

# === CIRCUIT BREAKER ===
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=60
CB_HALF_OPEN_MAX=3

# === SAGA ===
SAGA_MAX_RETRIES=3
SAGA_COMPENSATION_TIMEOUT=300

# === ARBITRATION ===
ARBITRATION_SIGNATURE_ENABLED=false
ARBITRATION_TIMESTAMP_SERVER=http://timestamp.digicert.com
# P1: Provider d'horodatage RFC 3161
#   auto          — détection automatique (haute_protection→local_hmac, standard→digicert)
#   local_hmac    — développement, non qualifié
#   swisssign     — Suisse, qualifié ZertES
#   certigna      — France, qualifié eIDAS
#   digicert      — International
ARBITRATION_TIMESTAMP_PROVIDER=auto
ARBITRATION_PRECEDENT_FILE=./data/precedents.json
# P0: Chaîne d'escalade — liste des arbitres dans l'ordre
ARBITRATION_ESCALATION_CHAIN=["expert", "expert_suppleant", "associe"]
# P0: Timeout par niveau d'escalade (heures)
ARBITRATION_ESCALATION_TIMEOUT_HOURS=[2.0, 4.0, 8.0]

# === COMPLIANCE ===
COMPLIANCE_DATA_RESIDENCY=EU
COMPLIANCE_ENCRYPTION=AES-256
COMPLIANCE_AUDIT_INTERVAL=daily
COMPLIANCE_REPORT_DIR=./data/reports

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# === SECURITY ===
SECRET_KEY=change_this_in_production
# Mot de passe admin initial — OBLIGATOIRE de définir en production
SEED_ADMIN_PASSWORD=
MTLS_ENABLED=false
MTLS_CERT_PATH=
MTLS_KEY_PATH=
MTLS_CA_PATH=

# === DATABASE ===
# PostgreSQL (production):
# DATABASE_URL=postgresql://cortex:cortex_dev_2024@localhost:5432/cortex_leman
# SQLite (dev):
DATABASE_URL=sqlite:///./data/cortex-leman.db

# === JWT ===
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# === ENCRYPTION ===
ENCRYPTION_ENABLED=true

# === VERTICAL ===
# active vertical for rules: comptable|avocat|sante|banque|startup|rh
ACTIVE_VERTICAL=comptable
